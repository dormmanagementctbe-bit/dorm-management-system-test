// Dorm Management System — Prisma Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum RoleCode {
  STUDENT
  DORM_HEAD
  ADMIN
  SUPER_ADMIN
  MAINTENANCE

  @@map("role_code")
}

enum Gender {
  MALE
  FEMALE

  @@map("gender")
}

enum StudyYearRoman {
  I
  II
  III
  IV
  V

  @@map("study_year_roman")
}

enum DormGenderRestriction {
  MALE_ONLY
  FEMALE_ONLY

  @@map("dorm_gender_restriction")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED

  @@map("user_status")
}

enum RoomStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE

  @@map("room_status")
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE

  @@map("bed_status")
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  ALLOCATED
  CANCELLED

  @@map("application_status")
}

enum AllocationStatus {
  PENDING_CHECKIN
  ACTIVE
  EXPIRED
  CANCELLED

  @@map("allocation_status")
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  FURNITURE
  OTHER

  @@map("maintenance_category")
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT

  @@map("maintenance_priority")
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED

  @@map("maintenance_status")
}

enum NotificationType {
  APPLICATION
  ALLOCATION
  MAINTENANCE
  SYSTEM
  REMINDER

  @@map("notification_type")
}

enum SupportDomain {
  FOOD
  HOUSING

  @@map("support_domain")
}

enum SupportMode {
  CASH
  IN_KIND

  @@map("support_mode")
}

enum ApplicationDocumentType {
  ID_IMAGE
  HIGHSCHOOL_TRANSCRIPT
  ENTRANCE_EXAM_RESULT
  KEBELE_VERIFICATION
  STAFF_RECOGNITION
  MEDICAL_DOCUMENT

  @@map("application_document_type")
}

enum ApplicationDocumentStatus {
  UPLOADED
  PENDING_REVIEW
  VERIFIED
  REJECTED
  ON_ARRIVAL_VERIFIED

  @@map("application_document_status")
}



// ─────────────────────────────────────────
// Models
// ─────────────────────────────────────────

model User {
  id                     String     @id @default(uuid()) @db.Uuid
  email                  String     @unique
  passwordHash           String     @map("password_hash")
  status                 UserStatus @default(ACTIVE)
  isEmailVerified        Boolean    @default(false) @map("is_email_verified")
  lastLoginAt            DateTime?  @map("last_login_at")
  failedLoginAttempts    Int        @default(0) @map("failed_login_attempts")
  passwordResetToken     String?    @map("password_reset_token")
  passwordResetExpiresAt DateTime?  @map("password_reset_expires_at")
  mustChangePassword     Boolean    @default(false) @map("must_change_password")
  firstLoginOtpHash      String?    @map("first_login_otp_hash")
  firstLoginOtpExpiresAt DateTime?  @map("first_login_otp_expires_at")
  firstLoginOtpAttempts  Int        @default(0) @map("first_login_otp_attempts")
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")
  deletedAt              DateTime?  @map("deleted_at")

  student                      Student?
  userRoles                    UserRole[]
  assignedRoles                UserRole[]                @relation("AssignedBy")
  notifications                Notification[]
  reportedMaintenanceRequests  MaintenanceRequest[]      @relation("ReportedBy")
  assignedMaintenanceRequests  MaintenanceRequest[]      @relation("AssignedTo")
  allocatedBy                  Allocation[]              @relation("AllocatedBy")
  reviewedApplications         DormApplication[]         @relation("ReviewedBy")
  reviewedApplicationDocuments ApplicationDocument[]     @relation("ApplicationDocumentReviewedBy")
  createdCityPriorityRules     CityPriorityRule[]        @relation("CreatedBy")
  createdDisabilityRules       DisabilityPriorityRule[]  @relation("CreatedBy")
  auditLogs                    AuditLog[]
  refreshSessions              RefreshSession[]

  @@index([email])
  @@index([status])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        RoleCode @unique
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userRoles UserRole[]

  @@map("roles")
}

model UserRole {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  roleId           String   @map("role_id") @db.Uuid
  assignedAt       DateTime @default(now()) @map("assigned_at")
  assignedByUserId String?  @map("assigned_by_user_id") @db.Uuid

  user         User  @relation(fields: [userId], references: [id])
  role         Role  @relation(fields: [roleId], references: [id])
  assignedBy   User? @relation("AssignedBy", fields: [assignedByUserId], references: [id])

  @@unique([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model Student {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @unique @map("user_id") @db.Uuid
  studentNumber          String    @unique @map("student_number")
  firstName              String    @map("first_name")
  fatherName             String?   @map("father_name")
  grandfatherName        String    @map("grandfather_name")
  gender                 Gender
  studyYear              StudyYearRoman @map("study_year")
  department             String?
  phone                  String?
  guardianName           String?   @map("guardian_name")
  guardianPhone          String?   @map("guardian_phone")
  emergencyContactName   String?   @map("emergency_contact_name")
  emergencyContactPhone  String?   @map("emergency_contact_phone")
  hasDisability          Boolean   @default(false) @map("has_disability")
  disabilityNotes        String?   @map("disability_notes")
  scholarshipNotes       String?   @map("scholarship_notes")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")
  deletedAt              DateTime? @map("deleted_at")

  user                   User                        @relation(fields: [userId], references: [id])
  supportPreferences     StudentSupportPreference[]
  applications           DormApplication[]
  allocations            Allocation[]

  @@index([studentNumber])
  @@index([gender])
  @@index([studyYear])
  @@index([hasDisability])
  @@map("students")
}

model StudentSupportPreference {
  id        String        @id @default(uuid()) @db.Uuid
  studentId String        @map("student_id") @db.Uuid
  domain    SupportDomain
  mode      SupportMode
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, domain])
  @@index([domain, mode])
  @@map("student_support_preferences")
}

model AcademicYear {
  id                     String    @id @default(uuid()) @db.Uuid
  label                  String    @unique
  startDate              DateTime  @map("start_date") @db.Date
  endDate                DateTime  @map("end_date") @db.Date
  applicationOpenDate    DateTime  @map("application_open_date") @db.Date
  applicationCloseDate   DateTime  @map("application_close_date") @db.Date
  isActive               Boolean   @default(false) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  semesters              Semester[]
  applications           DormApplication[]
  allocations            Allocation[]
  cityPriorityRules      CityPriorityRule[]
  disabilityPriorityRules DisabilityPriorityRule[]

  @@index([isActive])
  @@map("academic_years")
}

model Semester {
  id                     String    @id @default(uuid()) @db.Uuid
  academicYearId         String    @map("academic_year_id") @db.Uuid
  name                   String
  startDate              DateTime  @map("start_date") @db.Date
  endDate                DateTime  @map("end_date") @db.Date
  applicationOpenDate    DateTime? @map("application_open_date") @db.Date
  applicationCloseDate   DateTime? @map("application_close_date") @db.Date
  isActive               Boolean   @default(false) @map("is_active")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  academicYear           AcademicYear             @relation(fields: [academicYearId], references: [id])
  allocations            Allocation[]
  cityPriorityRules      CityPriorityRule[]
  disabilityPriorityRules DisabilityPriorityRule[]

  @@unique([academicYearId, name])
  @@index([academicYearId, isActive])
  @@map("semesters")
}

model Block {
  id          String    @id @default(uuid()) @db.Uuid
  code        String    @unique
  name        String    @unique
  location    String?
  totalFloors Int       @default(1) @map("total_floors")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  dorms       Dorm[]
  allocations Allocation[]

  @@map("blocks")
}

model Dorm {
  id                String                 @id @default(uuid()) @db.Uuid
  blockId           String                 @map("block_id") @db.Uuid
  code              String                 @unique
  name              String                 @unique // e.g., "Dorm 101" 
  floorNumber       Int                    @map("floor_number")
  genderRestriction DormGenderRestriction  @map("gender_restriction")
  capacity          Int
  status            RoomStatus             @default(ACTIVE)
  isActive          Boolean                @default(true) @map("is_active")
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")
  deletedAt         DateTime?              @map("deleted_at")

  block                  Block                   @relation(fields: [blockId], references: [id])
  beds                   Bed[]
  allocations            Allocation[]
  maintenanceRequests    MaintenanceRequest[]

  @@index([blockId])
  @@index([genderRestriction])
  @@index([status])
  @@index([isActive])
  @@map("dorms")
}

model Bed {
  id        String    @id @default(uuid()) @db.Uuid
  dormId    String    @map("dorm_id") @db.Uuid
  bedNumber String    @map("bed_number")
  status    BedStatus @default(AVAILABLE)
  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  dorm        Dorm         @relation(fields: [dormId], references: [id])
  allocations Allocation[]

  @@unique([dormId, bedNumber])
  @@index([dormId, status])
  @@index([isActive])
  @@map("beds")
}

model CityPriorityRule {
  id               String    @id @default(uuid()) @db.Uuid
  academicYearId   String    @map("academic_year_id") @db.Uuid
  semesterId       String?   @map("semester_id") @db.Uuid
  cityName         String    @map("city_name")
  score            Int
  createdByUserId  String    @map("created_by_user_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  semester     Semester?    @relation(fields: [semesterId], references: [id])
  createdBy    User         @relation("CreatedBy", fields: [createdByUserId], references: [id])

  @@unique([academicYearId, semesterId, cityName])
  @@map("city_priority_rules")
}

model DisabilityPriorityRule {
  id               String    @id @default(uuid()) @db.Uuid
  academicYearId   String    @map("academic_year_id") @db.Uuid
  semesterId       String?   @map("semester_id") @db.Uuid
  fixedScore       Int       @map("fixed_score")
  isActive         Boolean   @default(true) @map("is_active")
  createdByUserId  String    @map("created_by_user_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  semester     Semester?    @relation(fields: [semesterId], references: [id])
  createdBy    User         @relation("CreatedBy", fields: [createdByUserId], references: [id])

  @@unique([academicYearId, semesterId])
  @@map("disability_priority_rules")
}

model DormApplication {
  id                     String            @id @default(uuid()) @db.Uuid
  studentId              String            @map("student_id") @db.Uuid
  academicYearId         String            @map("academic_year_id") @db.Uuid
  studentFullName        String?           @map("student_full_name")
  referenceNumber        String?           @unique @map("reference_number")
  currentSubcity         String?           @map("current_subcity")
  currentWoreda          String?           @map("current_woreda")
  hasDisability          Boolean           @default(false) @map("has_disability")
  disabilityType         String?           @map("disability_type")
  medicalCondition       String?           @map("medical_condition")
  canEditUntil           DateTime?         @map("can_edit_until")
  editOverrideUntil      DateTime?         @map("edit_override_until")
  basePriorityScore      Int               @default(0) @map("base_priority_score")
  disabilityBonusScore   Int               @default(0) @map("disability_bonus_score")
  manualAdjustmentScore  Int               @default(0) @map("manual_adjustment_score")
  finalPriorityScore     Int               @default(0) @map("final_priority_score")
  status                 ApplicationStatus @default(PENDING)
  reason                 String?
  submittedAt            DateTime          @default(now()) @map("submitted_at")
  reviewedAt             DateTime?         @map("reviewed_at")
  reviewedByUserId       String?           @map("reviewed_by_user_id") @db.Uuid
  reviewNote             String?           @map("review_note")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  student            Student                 @relation(fields: [studentId], references: [id])
  academicYear       AcademicYear            @relation(fields: [academicYearId], references: [id])
  reviewedBy         User?                   @relation("ReviewedBy", fields: [reviewedByUserId], references: [id])
  documents          ApplicationDocument[]
  allocation         Allocation?

  @@unique([studentId, academicYearId])
  @@index([academicYearId, status])
  @@index([finalPriorityScore])
  @@map("dorm_applications")
}

model ApplicationDocument {
  id             String                    @id @default(uuid()) @db.Uuid
  applicationId  String                    @map("application_id") @db.Uuid
  type           ApplicationDocumentType
  originalName   String                    @map("original_name")
  storagePath    String                    @map("storage_path")
  mimeType       String                    @map("mime_type")
  sizeBytes      Int                       @map("size_bytes")
  status         ApplicationDocumentStatus @default(UPLOADED)
  reviewedAt     DateTime?                 @map("reviewed_at")
  reviewedByUserId String?                 @map("reviewed_by_user_id") @db.Uuid
  reviewNote     String?                   @map("review_note")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  application    DormApplication           @relation(fields: [applicationId], references: [id])
  reviewedBy     User?                     @relation("ApplicationDocumentReviewedBy", fields: [reviewedByUserId], references: [id])

  @@unique([applicationId, type])
  @@index([type, status])
  @@map("application_documents")
}

model Allocation {
  id                String           @id @default(uuid()) @db.Uuid
  studentId         String           @map("student_id") @db.Uuid
  applicationId     String           @unique @map("application_id") @db.Uuid
  academicYearId    String           @map("academic_year_id") @db.Uuid
  semesterId        String           @map("semester_id") @db.Uuid
  blockId           String           @map("block_id") @db.Uuid
  dormId            String           @map("dorm_id") @db.Uuid
  bedId             String           @map("bed_id") @db.Uuid
  
  status            AllocationStatus @default(PENDING_CHECKIN)
  startDate         DateTime         @map("start_date") @db.Date
  endDate           DateTime         @map("end_date") @db.Date
  allocatedByUserId String           @map("allocated_by_user_id") @db.Uuid
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  student      Student         @relation(fields: [studentId], references: [id])
  application  DormApplication @relation(fields: [applicationId], references: [id])
  academicYear AcademicYear    @relation(fields: [academicYearId], references: [id])
  semester     Semester        @relation(fields: [semesterId], references: [id])
  block        Block           @relation(fields: [blockId], references: [id])
  dorm         Dorm            @relation(fields: [dormId], references: [id])
  bed          Bed             @relation(fields: [bedId], references: [id])
  
  allocatedBy  User            @relation("AllocatedBy", fields: [allocatedByUserId], references: [id])

  @@index([studentId, academicYearId, semesterId])
  @@index([bedId, status])
  @@index([dormId, status])  // Added: filter by room status
  @@index([blockId, status]) // Added: filter by block status
  @@index([academicYearId, semesterId, status])
  @@map("allocations")
}

model MaintenanceRequest {
  id               String              @id @default(uuid()) @db.Uuid
  dormId           String              @map("room_id") @db.Uuid
  reportedByUserId String              @map("reported_by_user_id") @db.Uuid
  assignedToUserId String?             @map("assigned_to_user_id") @db.Uuid
  category         MaintenanceCategory
  priority         MaintenancePriority @default(MEDIUM)
  status           MaintenanceStatus   @default(OPEN)
  title            String
  description      String
  resolvedAt       DateTime?           @map("resolved_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  dorm        Dorm  @relation(fields: [dormId], references: [id])
  reportedBy  User  @relation("ReportedBy", fields: [reportedByUserId], references: [id])
  assignedTo  User? @relation("AssignedTo", fields: [assignedToUserId], references: [id])

  @@index([status, priority])
  @@index([dormId])
  @@index([reportedByUserId])
  @@index([assignedToUserId])
  @@map("maintenance_requests")
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  title       String
  message     String
  type        NotificationType
  isRead      Boolean          @default(false) @map("is_read")
  readAt      DateTime?        @map("read_at")
  emailSentAt DateTime?        @map("email_sent_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  actorUserId   String?  @map("actor_user_id") @db.Uuid
  entityName    String   @map("entity_name")
  entityId      String   @map("entity_id") @db.Uuid
  action        String
  oldValues     Json?    @map("old_values")
  newValues     Json?    @map("new_values")
  createdAt     DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorUserId], references: [id])

  @@index([entityName, entityId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

model RefreshSession {
  id                String          @id @default(uuid()) @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  tokenJti          String          @unique @map("token_jti")
  tokenHash         String          @unique @map("token_hash")
  expiresAt         DateTime        @map("expires_at")
  lastUsedAt        DateTime?       @map("last_used_at")
  revokedAt         DateTime?       @map("revoked_at")
  revokedReason     String?         @map("revoked_reason")
  replacedBySessionId String?       @map("replaced_by_session_id") @db.Uuid
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  user              User            @relation(fields: [userId], references: [id])
  replacedBy        RefreshSession? @relation("RefreshSessionReplacement", fields: [replacedBySessionId], references: [id])
  replacedSessions  RefreshSession[] @relation("RefreshSessionReplacement")

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_sessions")
}
