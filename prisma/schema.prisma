// Dorm Management System — Prisma Schema
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// Enums
// ─────────────────────────────────────────

enum Role {
  STUDENT
  ADMIN
  SUPER_ADMIN
}

enum AdminLevel {
  STAFF
  MANAGER
  SUPER
}

enum GenderPolicy {
  MALE
  FEMALE
  MIXED
}

enum RoomType {
  SINGLE
  DOUBLE
  TRIPLE
  QUAD
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  RESERVED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
  ALLOCATED
}

enum AllocationStatus {
  PENDING_CHECKIN
  ACTIVE
  EXPIRED
  CANCELLED
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  HVAC
  FURNITURE
  CLEANING
  OTHER
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
  REJECTED
}

enum NotificationType {
  ALLOCATION
  APPLICATION
  MAINTENANCE
  SYSTEM
  REMINDER
}

// ─────────────────────────────────────────
// Models
// ─────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(STUDENT)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student             Student?
  admin               Admin?
  notifications       Notification[]
  reportedMaintenance MaintenanceRequest[] @relation("ReportedBy")

  @@map("users")
}

model Student {
  id                  String   @id @default(uuid())
  userId              String   @unique @map("user_id")
  studentId           String   @unique @map("student_id")
  firstName           String   @map("first_name")
  lastName            String   @map("last_name")
  academicYear        Int      @map("academic_year")
  department          String
  phone               String?
  distanceKm          Float    @default(0) @map("distance_km")
  costSharingEligible Boolean  @default(false) @map("cost_sharing_eligible")
  createdAt           DateTime @default(now()) @map("created_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications DormApplication[]
  allocations  Allocation[]

  @@index([studentId])
  @@index([academicYear])
  @@index([costSharingEligible])
  @@map("students")
}

model Admin {
  id         String     @id @default(uuid())
  userId     String     @unique @map("user_id")
  firstName  String     @map("first_name")
  lastName   String     @map("last_name")
  phone      String?
  adminLevel AdminLevel @default(STAFF) @map("admin_level")
  createdAt  DateTime   @default(now()) @map("created_at")

  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedApplications DormApplication[]    @relation("ReviewedBy")
  allocations          Allocation[]         @relation("AllocatedBy")
  assignedMaintenance  MaintenanceRequest[] @relation("AssignedTo")

  @@map("admins")
}

model AcademicYear {
  id               String   @id @default(uuid())
  label            String   @unique
  startDate        DateTime @map("start_date") @db.Date
  endDate          DateTime @map("end_date") @db.Date
  isActive         Boolean  @default(false) @map("is_active")
  applicationOpen  DateTime @map("application_open") @db.Date
  applicationClose DateTime @map("application_close") @db.Date

  applications DormApplication[]
  allocations  Allocation[]

  @@map("academic_years")
}

model Dorm {
  id           String       @id @default(uuid())
  name         String
  location     String
  genderPolicy GenderPolicy @default(MIXED) @map("gender_policy")
  totalRooms   Int          @default(0) @map("total_rooms")
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")

  rooms        Room[]
  applications DormApplication[] @relation("PreferredDorm")

  @@index([isActive])
  @@map("dorms")
}

model Room {
  id          String     @id @default(uuid())
  dormId      String     @map("dorm_id")
  roomNumber  String     @map("room_number")
  capacity    Int
  roomType    RoomType   @map("room_type")
  status      RoomStatus @default(AVAILABLE)
  monthlyRate Decimal    @map("monthly_rate") @db.Decimal(10, 2)
  createdAt   DateTime   @default(now()) @map("created_at")

  dorm        Dorm                 @relation(fields: [dormId], references: [id])
  allocations Allocation[]
  maintenance MaintenanceRequest[]

  @@unique([dormId, roomNumber])
  @@index([dormId, status])
  @@map("rooms")
}

model DormApplication {
  id              String            @id @default(uuid())
  studentId       String            @map("student_id")
  academicYearId  String            @map("academic_year_id")
  preferredDormId String?           @map("preferred_dorm_id")
  status          ApplicationStatus @default(PENDING)
  priorityScore   Float             @default(0) @map("priority_score")
  reason          String?
  submittedAt     DateTime          @default(now()) @map("submitted_at")
  reviewedAt      DateTime?         @map("reviewed_at")
  reviewedById    String?           @map("reviewed_by_id")
  reviewNote      String?           @map("review_note")

  student       Student      @relation(fields: [studentId], references: [id])
  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id])
  preferredDorm Dorm?        @relation("PreferredDorm", fields: [preferredDormId], references: [id])
  reviewedBy    Admin?       @relation("ReviewedBy", fields: [reviewedById], references: [id])
  allocation    Allocation?

  @@unique([studentId, academicYearId])
  @@index([academicYearId, status])
  @@map("dorm_applications")
}

model Allocation {
  id             String           @id @default(uuid())
  studentId      String           @map("student_id")
  roomId         String           @map("room_id")
  applicationId  String           @unique @map("application_id")
  academicYearId String           @map("academic_year_id")
  startDate      DateTime         @map("start_date") @db.Date
  endDate        DateTime         @map("end_date") @db.Date
  status         AllocationStatus @default(PENDING_CHECKIN)
  allocatedById  String           @map("allocated_by_id")
  createdAt      DateTime         @default(now()) @map("created_at")

  student      Student         @relation(fields: [studentId], references: [id])
  room         Room            @relation(fields: [roomId], references: [id])
  application  DormApplication @relation(fields: [applicationId], references: [id])
  academicYear AcademicYear    @relation(fields: [academicYearId], references: [id])
  allocatedBy  Admin           @relation("AllocatedBy", fields: [allocatedById], references: [id])

  @@index([studentId, status])
  @@index([roomId, status])
  @@index([academicYearId])
  @@map("allocations")
}

model MaintenanceRequest {
  id           String              @id @default(uuid())
  roomId       String              @map("room_id")
  reportedById String              @map("reported_by_id")
  category     MaintenanceCategory
  priority     MaintenancePriority @default(MEDIUM)
  status       MaintenanceStatus   @default(OPEN)
  title        String
  description  String
  assignedToId String?             @map("assigned_to_id")
  resolvedAt   DateTime?           @map("resolved_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  room       Room   @relation(fields: [roomId], references: [id])
  reportedBy User   @relation("ReportedBy", fields: [reportedById], references: [id])
  assignedTo Admin? @relation("AssignedTo", fields: [assignedToId], references: [id])

  @@index([status, priority])
  @@index([roomId])
  @@index([reportedById])
  @@map("maintenance_requests")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}
