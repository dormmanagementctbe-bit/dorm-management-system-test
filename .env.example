DATABASE_URL=postgresql://postgres:password@localhost:5432/dorm_management
JWT_SECRET=your-super-secret-key-at-least-32-characters-long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-at-least-32-characters-long
JWT_REFRESH_EXPIRES_IN=7d
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
PASSWORD_MIN_LENGTH=12
TEMP_PASSWORD_EXPIRY_DAYS=14
HIBP_API_ENABLED=false
HIBP_PWNED_COUNT_THRESHOLD=1
HIBP_FAIL_CLOSED=false
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=false
PORT=3000
NODE_ENV=development
BCRYPT_ROUNDS=12
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@dorm.local
